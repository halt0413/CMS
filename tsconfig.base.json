{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "jsx": "preserve",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "baseUrl": ".",
    "paths": {
      "@repo/github": ["packages/github/src/index.ts"],
      "@repo/content": ["packages/content/src/index.ts"],
      "@repo/types": ["packages/types/src/index.ts"],
      "@repo/utils": ["packages/utils/src/index.ts"]
    }
  }
}
